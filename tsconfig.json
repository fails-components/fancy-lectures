{
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true
  },
  "exclude": ["**/node_modules", "**/dist"],
  "references": [
    { "path": "./packages/commonhandler" },
    { "path": "./packages/config" },
    { "path": "./packages/data" },
    { "path": "./packages/drawobjects" },
    { "path": "./packages/security" }
  ]
}