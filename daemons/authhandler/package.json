{
  "name": "@fails-components/authhandler",
  "version": "1.2.11",
  "description": "Handles authentification using codes",
  "author": "Marten Richter",
  "license": "AGPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fails-components/fancy-lectures.git"
  },
  "main": "src/server.ts",
  "source": "src/server.ts",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "start": "node src/server.ts",
    "test": "run-s test:lint",
    "test:lint": "eslint .",
    "docker:build": "docker build -t ghcr.io/fails-components/authhandler:master --secret id=GH_TOKEN -f Dockerfile ../.."
  },
  "devDependencies": {
    "@types/node": "^25.3.0",
    "cross-env": "^7.0.3"
  },
  "files": [
    "src/*.ts",
    "failslogo.svg",
    "failslogolicensereadme.txt"
  ],
  "dependencies": {
    "@fails-components/config": "^1.3.0",
    "@fails-components/security": "^1.3.1",
    "redis": "^4.0.6",
    "socket.io": "^4.8.3",
    "uuid": "^13.0.0"
  },
  "nodemonConfig": {
    "ignore": [
      "files/*"
    ],
    "delay": 2500
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  }
