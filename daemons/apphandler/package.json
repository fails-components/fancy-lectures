{
  "name": "@fails-components/apphandler",
  "version": "1.2.22",
  "description": "Supplies server side app handling",
  "author": "Marten Richter",
  "license": "AGPL-3.0-or-later",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fails-components/apphandler.git"
  },
  "main": "src/server.js",
