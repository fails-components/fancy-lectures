  "devDependencies": {
    "cross-env": "^7.0.3",
    "dotenv": "^10.0.0"
  },
  "dependencies": {
    "@fails-components/assets": "^1.5.1",
    "@fails-components/commonhandler": "^1.2.18",
    "@fails-components/config": "^1.7.0",
    "@fails-components/data": "1.4.3",
    "@fails-components/security": "^1.5.1",
    "@socket.io/redis-adapter": "^7.1.0",
    "mongodb": "^7.1.0",
    "redis": "^4.0.6",
    "redlock-universal": "^0.8.2",
    "socket.io": "^4.8.3"
  },
  "nodemonConfig": {
    "ignore": [
      "files/*"
    ],
    "delay": 2500
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  }
}
