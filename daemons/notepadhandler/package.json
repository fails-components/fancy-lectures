{
  "name": "@fails-components/notepadhandler",
  "version": "1.2.18",
  "description": "Supplies server side notepad handling",
  "author": "Marten Richter",
  "license": "AGPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fails-components/fancy-lectures.git"
  },
  "private": true,
  "main": "src/server.ts",
  "source": "src/server.ts",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "files": [
    "src/*.ts",
    "failslogo.svg",
    "failslogolicensereadme.txt"
  ],
  "scripts": {
    "start": "node src/server.ts",
    "test": "run-s test:lint",
    "test:lint": "eslint .",
    "docker:build": "docker build -t ghcr.io/fails-components/notepadhandler:master --secret id=GH_TOKEN -f Dockerfile ../.."
