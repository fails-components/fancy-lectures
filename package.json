{
  "name": "fails-monorepo-root",
  "description": "Root of fails components mono repo",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "test": "npm test --workspaces --if-present",
    "build": "npm run build --workspaces --if-present",
    "start": "npm-run-all --parallel start:*",
    "start:app": "npm start -w packages/app",
    "start:lectureapp": "npm start -w packages/lectureapp",
    "serve": "npm-run-all --parallel serve:*",
    "serve:app": "npm run serve -w packages/app",
    "serve:lectureapp": "npm run serve -w packages/lectureapp"
  },
  "devDependencies": {
    "@babel/core": "^7.28.0",
    "@babel/eslint-parser": "^7.28.6",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "eslint-plugin-promise": "^7.2.1",
    "globals": "^17.3.0",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.5.3",
    "prettier-linter-helpers": "^1.0.0"
  }
}
