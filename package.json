{
  "name": "fails-monorepo-root",
  "description": "Root of fails components mono repo",
  "private": true,
  "workspaces": [
    "packages/*",
    "daemons/*",
    "deploy/migrateassets"
  ],
  "type": "module",
  "scripts": {
    "test": "lerna run test --concurrency 1",
    "build": "lerna run build --stream",
    "buildts": "tsc --build",
    "start": "lerna run start --parallel",
    "start:app": "lerna run start --scope @fails-components/app",
    "start:lectureapp": "lerna run start --scope @fails-components/lectureapp",
    "lint": "eslint .",
    "syncpack:lint": "syncpack lint --dependency-types prod,dev",
    "syncpack:lint:fix": "syncpack fix --dependency-types prod,dev",
    "syncpack:lint:format": "syncpack format --dependency-types prod,dev",
    "serve": "lerna run serve --parallel",
    "serve:app": "lerna run serve --scope @fails-components/app",
    "serve:lectureapp": "lerna run serve --scope @fails-components/lectureapp",
    "docker:build": "lerna run docker:build  --concurrency 1 --stream",
    "version:new": "lerna version --no-push",
    "publish:start": "lerna publish from-git"
  },
  "devDependencies": {
    "@babel/core": "^7.28.0",
    "@babel/eslint-parser": "^7.28.6",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "eslint-plugin-promise": "^7.2.1",
    "globals": "^17.3.0",
    "isolate-package": "^1.29.0",
    "lerna": "^9.0.7",
    "prettier": "^3.5.3",
    "prettier-linter-helpers": "^1.0.0",
    "syncpack": "^14.2.0",
    "typescript-eslint": "^8.55.0"
  }
}
